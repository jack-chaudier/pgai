# Twilio — telephony (outbound calls + media streams WebSocket)
# Sign up: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX  # Your Twilio number in E.164 format

# AWS Bedrock — Nova Sonic speech-to-speech model
# Sign up: https://aws.amazon.com/bedrock/
# Enable model access for amazon.nova-2-sonic-v1:0 in us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1

# Google AI — Gemini 2.5 Flash for post-call transcript analysis
# Sign up: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# Target phone number (Pretty Good AI test line)
TARGET_PHONE_NUMBER=+18054398008

# Optional: ngrok for exposing local webhook server
# NGROK_AUTHTOKEN=your_ngrok_token
